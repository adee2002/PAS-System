@{
    ViewData["Title"] = "Student Module";
}

<div class="bg-shape bg-shape-one" aria-hidden="true"></div>
<div class="bg-shape bg-shape-two" aria-hidden="true"></div>

<main class="app-shell">
    <header class="hero fade-in">
        <p class="eyebrow">Student Module</p>
        <h1>Project Submission Workspace</h1>
        <p class="hero-copy">
            Submit project ideas, update them before matching, and track status across
            <strong>Pending</strong>, <strong>Under Review</strong>, and <strong>Matched</strong>.
        </p>
    </header>

    <section class="layout-grid">
        <article class="panel form-panel fade-in">
            <div class="panel-head">
                <h2 id="form-title">Submit Project</h2>
                <p>Fill all fields to submit your proposal.</p>
            </div>

            <form id="project-form" novalidate>
                <label class="input-group">
                    <span>Title</span>
                    <input id="title" name="title" type="text" placeholder="e.g., Smart Research Matching" required>
                </label>

                <label class="input-group">
                    <span>Abstract</span>
                    <textarea
                        id="abstract"
                        name="abstract"
                        rows="4"
                        placeholder="Briefly describe your project idea and problem it solves."
                        required
                    ></textarea>
                </label>

                <label class="input-group">
                    <span>Tech Stack</span>
                    <input id="techStack" name="techStack" type="text" placeholder="e.g., ASP.NET Core, React, SQL Server" required>
                </label>

                <label class="input-group">
                    <span>Research Area</span>
                    <input id="researchArea" name="researchArea" type="text" placeholder="e.g., Web Development, AI, Cybersecurity" required>
                </label>

                <div class="form-actions">
                    <button type="submit" id="submit-btn" class="btn btn-primary">Submit Project</button>
                    <button type="button" id="cancel-edit-btn" class="btn btn-muted hidden">Cancel Edit</button>
                </div>
            </form>
        </article>

        <article class="panel list-panel fade-in">
            <div class="panel-head">
                <h2>Your Projects</h2>
                <p>Only projects that are not matched can be edited or deleted.</p>
            </div>

            <div class="status-toolbar">
                <div class="chips" role="tablist" aria-label="Filter by status">
                    <button class="chip active" data-filter="All" role="tab" aria-selected="true">All</button>
                    <button class="chip" data-filter="Pending" role="tab" aria-selected="false">Pending</button>
                    <button class="chip" data-filter="Under Review" role="tab" aria-selected="false">Under Review</button>
                    <button class="chip" data-filter="Matched" role="tab" aria-selected="false">Matched</button>
                </div>
                <input id="search" class="search" type="search" placeholder="Search by title...">
            </div>

            <div id="project-list" class="project-list" aria-live="polite"></div>
        </article>
    </section>
</main>

<template id="project-card-template">
    <article class="project-card">
        <div class="card-head">
            <h3 class="project-title"></h3>
            <span class="badge"></span>
        </div>
        <p class="project-abstract"></p>
        <dl class="meta-grid">
            <div>
                <dt>Tech Stack</dt>
                <dd class="project-stack"></dd>
            </div>
            <div>
                <dt>Research Area</dt>
                <dd class="project-area"></dd>
            </div>
        </dl>
        <div class="card-footer">
            <small class="project-date"></small>
            <div class="card-actions">
                <button class="btn btn-small btn-edit" type="button">Edit</button>
                <button class="btn btn-small btn-delete" type="button">Delete</button>
            </div>
        </div>
    </article>
</template>

@section Head {
    <link rel="stylesheet" href="~/css/student-module.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/student-module.js" asp-append-version="true"></script>
}