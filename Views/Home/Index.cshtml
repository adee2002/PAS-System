@{
    ViewData["Title"] = "Welcome to PAS";
}

<div class="welcome-section">
    <div class="main-logo">
        <i class="fas fa-project-diagram"></i>
    </div>
    <h1 style="color: #9C0759; font-weight: 700;">Welcome to PAS</h1>
    <p style="color: #700540; font-size: 1.1rem;">Project Approval System with Blind Matching</p>
    <p class="text-muted">Fair and unbiased project allocation for final-year students</p>

    @if (!User.Identity.IsAuthenticated)
    {
        <div class="get-started-card mt-4">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body text-center p-4">
                    <h5 class="mb-3">Get Started</h5>
                    <p class="text-muted mb-4">Login to access your dashboard</p>
                    <div class="d-flex gap-3 justify-content-center">
                        <a href="/Account/Login" class="btn btn-login">
                            <i class="fas fa-sign-in-alt me-2"></i> Login
                        </a>
                        <a href="/Account/Register" class="btn btn-register">
                            <i class="fas fa-user-plus me-2"></i> Register
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info mt-4" style="max-width: 500px; margin: 0 auto;">
            <i class="fas fa-smile-wink"></i> Welcome back!
            @if (User.IsInRole("Student"))
            {
                <a href="/Student/Dashboard" class="alert-link">Go to your Dashboard</a>
            }
            else if (User.IsInRole("Supervisor"))
            {
                <a href="/Supervisor/Dashboard" class="alert-link">Go to your Dashboard</a>
            }
            else if (User.IsInRole("ModuleLeader") || User.IsInRole("SystemAdmin"))
            {
                <a href="/Admin/Dashboard" class="alert-link">Go to Admin Dashboard</a>
            }
            else
            {
                <a href="/Account/Logout" class="alert-link">Click here to logout</a>
            }
        </div>
    }
</div>

<div class="row mt-5 g-4 justify-content-center">
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <h5>For Students</h5>
            <p>Submit project proposals, track status, and get matched with expert supervisors in your chosen field.</p>
            @if (!User.Identity.IsAuthenticated)
            {
                <a href="/Account/Register" class="btn btn-sm btn-outline-primary mt-2">Register as Student</a>
            }
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon">
                <i class="fas fa-chalkboard-teacher"></i>
            </div>
            <h5>For Supervisors</h5>
            <p>Review anonymous proposals, express interest, and mentor students in your areas of expertise.</p>
            @if (!User.Identity.IsAuthenticated)
            {
                <a href="/Account/Register" class="btn btn-sm btn-outline-primary mt-2">Register as Supervisor</a>
            }
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <div class="feature-icon">
                <i class="fas fa-eye-slash"></i>
            </div>
            <h5>Blind Matching</h5>
            <p>Fair and unbiased selection based on technical merit and area alignment, eliminating unconscious bias.</p>
        </div>
    </div>
</div>