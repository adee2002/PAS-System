@model ProjectApprovalSystem.Models.ViewModels.AdminAllocationViewModel

@{
    ViewData["Title"] = "Allocations";
}

<div class="container mt-4">
    <h1 class="mb-4">Student-Supervisor Allocations</h1>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5>Confirmed Matches</h5>
                    <h2>@Model.ConfirmedMatches</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5>Pending Matches</h5>
                    <h2>@Model.PendingMatches</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5>Total Matches</h5>
                    <h2>@Model.TotalMatches</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Project Title</th>
                            <th>Student</th>
                            <th>Supervisor</th>
                            <th>Match Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var match in Model.Matches)
                        {
                            <tr>
                                <td>@match.ProjectTitle</td>
                                <td>@match.StudentName<br /><small>@match.StudentEmail</small></td>
                                <td>@match.SupervisorName<br /><small>@match.SupervisorEmail</small></td>
                                <td>@match.MatchDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge bg-success">@match.Status</span></td>
                                <td>
                                    <form asp-action="ReassignProject" asp-route-matchId="@match.MatchId" method="post"
                                          onsubmit="return confirm('Reassign this project? This will reset the match.');">
                                        <button type="submit" class="btn btn-sm btn-warning">Reassign</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>